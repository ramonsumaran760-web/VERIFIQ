# --- Core ---
ENVIRONMENT=development
SECRET_KEY=change-me-in-production
ADMIN_API_TOKEN=change-me-admin-token
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://fxc-bbd.onrender.com
DATABASE_URL=sqlite:///./verifiq.db
# En producción: postgresql+psycopg2://user:pass@host:5432/verifiq

# --- Gate regulatorio para aliados ---
# Si RENIEC_API_KEY, AML_PROVIDER_TOKEN o TSA_CERTIFICATE quedan vacias, el
# sistema corre por defecto en Sandbox/Piloto usando mocks de simulacion.
RENIEC_API_KEY=
AML_PROVIDER_TOKEN=
TSA_CERTIFICATE=

# --- PSC / PAdES (firma digital certificada) ---
# Sin esto, /signatures/sign con signature_level=digital_certificada devuelve
# certificados MOCK. Contratar con Camerfirma o IO Digital (Perú/LatAm).
PSC_PROVIDER=mock
PSC_API_BASE_URL=
PSC_API_KEY=
PSC_TSA_URL=http://timestamp.digicert.com

# --- KYC biométrico ---
# incode | aws_rekognition | faceio
KYC_PROVIDER=mock
KYC_API_BASE_URL=
KYC_API_KEY=
FACEIO_PUBLIC_ID=
FACEIO_API_KEY=
AWS_REKOGNITION_REGION=

# --- RENIEC / SUNAT ---
# Requiere convenio institucional o un proveedor intermediario (ej. Apis Perú,
# Factiliza) — RENIEC no da acceso directo a empresas pequeñas sin convenio.
RENIEC_API_BASE_URL=
RENIEC_API_TOKEN=
SUNAT_API_BASE_URL=
SUNAT_API_TOKEN=

# --- AML / listas de sanciones ---
AML_PROVIDER=mock
AML_API_BASE_URL=
AML_API_KEY=

# --- Storage cifrado ---
STORAGE_BACKEND=local
S3_BUCKET=
S3_KMS_KEY_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Pagos ---
PAYMENTS_PROVIDER=mock
PAYMENTS_SECRET_KEY=
PAYMENTS_PUBLIC_KEY=
PAYMENTS_WEBHOOK_SECRET=

# --- Notificaciones a ops ---
# Slack/Discord incoming webhook. Sin esto, las alertas de manual_review solo van a logs.
NOTIFICATIONS_WEBHOOK_URL=

# --- Observabilidad ---
LOG_LEVEL=INFO
SENTRY_DSN=
